<UserControl
    x:Class="InstaDM.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="520">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock
                Text="Preferences stay on this PC only. Nothing is synced or uploaded."
                TextWrapping="Wrap"
                Opacity="0.75" />

            <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <ComboBox
                x:Name="AppearanceBox"
                Header="Native chrome theme"
                SelectionChanged="OnAppearanceChanged"
                MinWidth="240">
                <ComboBoxItem Content="System" Tag="System" />
                <ComboBoxItem Content="Light" Tag="Light" />
                <ComboBoxItem Content="Dark" Tag="Dark" />
            </ComboBox>

            <TextBlock Text="Notifications" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <ComboBox
                x:Name="notificationBox"
                Header="While the app is open"
                SelectionChanged="OnNotificationChanged"
                MinWidth="240">
                <ComboBoxItem Content="Off" Tag="Off" />
                <ComboBoxItem Content="Taskbar indicator only" Tag="Badge" />
                <ComboBoxItem Content="Generic banner + indicator" Tag="Standard" />
            </ComboBox>
            <ComboBox
                x:Name="pollIntervalBox"
                Header="Check interval"
                SelectionChanged="OnPollIntervalChanged"
                MinWidth="240">
                <ComboBoxItem Content="15 seconds" Tag="15" />
                <ComboBoxItem Content="30 seconds" Tag="30" />
                <ComboBoxItem Content="60 seconds" Tag="60" />
                <ComboBoxItem Content="120 seconds" Tag="120" />
            </ComboBox>
            <TextBlock
                Text="Banners never include names or message text. Polling stops when you close the app."
                TextWrapping="Wrap"
                Opacity="0.75" />

            <TextBlock Text="Surfaces" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <ToggleSwitch
                x:Name="followRequestsToggle"
                Header="Follow Requests (optional)"
                OffContent="Off"
                OnContent="On"
                Toggled="OnFollowRequestsToggled" />
            <TextBlock
                Text="Applies the next time the app starts. Shared Posts stay unavailable in this release."
                TextWrapping="Wrap"
                Opacity="0.75" />

            <ToggleSwitch
                x:Name="externalLinksToggle"
                Header="Open non-Instagram links in the system browser (not yet active)"
                OffContent="Block (default)"
                OnContent="Reserved"
                IsEnabled="False"
                Toggled="OnExternalLinksToggled" />
            <TextBlock
                Text="External-browser handoff is disabled until it can open a bare URL with no cookies, headers, or referrer."
                TextWrapping="Wrap"
                Opacity="0.75" />

            <TextBlock Text="Data" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <Button Content="Clear Instagram data and sign out" Click="OnClearInstagramData" />
            <TextBlock
                Text="Removes cookies and site data from this app's private browser profile only."
                TextWrapping="Wrap"
                Opacity="0.75" />
            <Button Content="Reset app settings" Click="OnResetSettings" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
